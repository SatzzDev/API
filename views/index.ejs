<style>
*{margin:0;padding:0;box-sizing:border-box}
[data-theme="cyberapi"]{
--bg-primary:#0d1117;
--bg-secondary:#161b22;
--bg-card:#1c2128;
--bg-hover:#21262d;
--border:#30363d;
--border-hover:#485461;
--text-primary:#e6edf3;
--text-secondary:#8b949e;
--text-muted:#6e7681;
--accent-cyan:#00f5ff;
--accent-purple:#a855f7;
--accent-pink:#ec4899;
--accent-blue:#3b82f6;
--accent-green:#22c55e;
--accent-orange:#f97316;
--shadow-sm:0 2px 4px rgba(0,0,0,0.3);
--shadow-md:0 4px 12px rgba(0,0,0,0.4);
--shadow-lg:0 8px 32px rgba(0,0,0,0.5);
--shadow-glow-cyan:0 0 20px rgba(0,245,255,0.3);
--shadow-glow-purple:0 0 20px rgba(168,85,247,0.3);
}
body{
font-family:'Inter',system-ui,sans-serif;
background:var(--bg-primary);
color:var(--text-primary);
line-height:1.6;
}
.font-mono{font-family:'JetBrains Mono',monospace}
.text-cyan{color:var(--accent-cyan)}
.text-purple{color:var(--accent-purple)}
.text-pink{color:var(--accent-pink)}
.text-blue{color:var(--accent-blue)}
.text-green{color:var(--accent-green)}
.text-orange{color:var(--accent-orange)}
.bg-cyan{background:var(--accent-cyan)}
.bg-purple{background:var(--accent-purple)}
.bg-pink{background:var(--accent-pink)}
.bg-blue{background:var(--accent-blue)}
.bg-green{background:var(--accent-green)}
.bg-orange{background:var(--accent-orange)}
.border{border:1px solid var(--border)}
.border-hover{border:1px solid var(--border);transition:border-color 0.2s}
.border-hover:hover{border-color:var(--border-hover)}
.gradient-text{
background:linear-gradient(135deg,var(--accent-cyan) 0%,var(--accent-purple) 50%,var(--accent-pink) 100%);
background-clip:text;
-webkit-background-clip:text;
color:transparent;
}
.gradient-cyan{background:linear-gradient(135deg,var(--accent-cyan) 0%,color-mix(in oklab,var(--accent-cyan) 70%,var(--bg-primary) 30%) 100%)}
.gradient-purple{background:linear-gradient(135deg,var(--accent-purple) 0%,color-mix(in oklab,var(--accent-purple) 70%,var(--bg-primary) 30%) 100%)}
.btn-primary{
background:var(--accent-cyan);
color:var(--bg-primary);
font-weight:600;
border:none;
padding:0.625rem 1.25rem;
border-radius:0.5rem;
transition:all 0.2s ease;
box-shadow:var(--shadow-sm);
}
.btn-primary:hover{
background:color-mix(in oklab,var(--accent-cyan) 85%,white 15%);
box-shadow:var(--shadow-glow-cyan);
transform:translateY(-1px);
}
.btn-secondary{
background:var(--bg-hover);
color:var(--text-primary);
font-weight:500;
border:1px solid var(--border);
padding:0.625rem 1.25rem;
border-radius:0.5rem;
transition:all 0.2s ease;
}
.btn-secondary:hover{
background:var(--border);
border-color:var(--border-hover);
}
.card{
background:var(--bg-card);
border:1px solid var(--border);
border-radius:0.75rem;
padding:1.5rem;
transition:all 0.3s ease;
}
.card-hover{
background:var(--bg-card);
border:1px solid var(--border);
border-radius:0.75rem;
padding:1.25rem;
transition:all 0.3s ease;
cursor:pointer;
}
.card-hover:hover{
border-color:var(--accent-cyan);
box-shadow:var(--shadow-md),var(--shadow-glow-cyan);
transform:translateY(-2px);
}
.stat-card{
background:var(--bg-secondary);
border:1px solid var(--border);
border-radius:0.75rem;
padding:1.25rem;
transition:all 0.3s ease;
position:relative;
overflow:hidden;
}
.stat-card::before{
content:'';
position:absolute;
top:0;left:0;right:0;height:2px;
background:linear-gradient(90deg,var(--accent-cyan),var(--accent-purple),var(--accent-pink));
opacity:0;
transition:opacity 0.3s;
}
.stat-card:hover{
border-color:var(--border-hover);
transform:translateY(-2px);
box-shadow:var(--shadow-md);
}
.stat-card:hover::before{opacity:1}
.badge{
display:inline-flex;
align-items:center;
gap:0.375rem;
padding:0.25rem 0.625rem;
border-radius:0.375rem;
font-size:0.75rem;
font-weight:500;
font-family:'JetBrains Mono',monospace;
border:1px solid var(--border);
}
.badge-cyan{background:color-mix(in oklab,var(--accent-cyan) 15%,var(--bg-primary));color:var(--accent-cyan);border-color:color-mix(in oklab,var(--accent-cyan) 30%,var(--border))}
.badge-purple{background:color-mix(in oklab,var(--accent-purple) 15%,var(--bg-primary));color:var(--accent-purple);border-color:color-mix(in oklab,var(--accent-purple) 30%,var(--border))}
.badge-pink{background:color-mix(in oklab,var(--accent-pink) 15%,var(--bg-primary));color:var(--accent-pink);border-color:color-mix(in oklab,var(--accent-pink) 30%,var(--border))}
.badge-blue{background:color-mix(in oklab,var(--accent-blue) 15%,var(--bg-primary));color:var(--accent-blue);border-color:color-mix(in oklab,var(--accent-blue) 30%,var(--border))}
.badge-green{background:color-mix(in oklab,var(--accent-green) 15%,var(--bg-primary));color:var(--accent-green);border-color:color-mix(in oklab,var(--accent-green) 30%,var(--border))}
.badge-orange{background:color-mix(in oklab,var(--accent-orange) 15%,var(--bg-primary));color:var(--accent-orange);border-color:color-mix(in oklab,var(--accent-orange) 30%,var(--border))}
.search-input{
width:100%;
background:var(--bg-secondary);
border:1px solid var(--border);
border-radius:0.5rem;
padding:0.75rem 1rem 0.75rem 2.5rem;
color:var(--text-primary);
font-size:0.875rem;
transition:all 0.2s ease;
}
.search-input:focus{
outline:none;
border-color:var(--accent-cyan);
box-shadow:var(--shadow-glow-cyan);
}
.search-input::placeholder{color:var(--text-muted)}
.search-icon{
position:absolute;
left:0.875rem;
top:50%;
transform:translateY(-50%);
color:var(--text-muted);
}
.nav-link{
display:flex;
align-items:center;
gap:0.75rem;
padding:0.75rem 1rem;
color:var(--text-secondary);
border-radius:0.5rem;
transition:all 0.2s ease;
font-weight:500;
}
.nav-link:hover{
background:var(--bg-hover);
color:var(--text-primary);
}
.nav-link.active{
background:color-mix(in oklab,var(--accent-cyan) 12%,var(--bg-primary));
color:var(--accent-cyan);
border-left:3px solid var(--accent-cyan);
}
.progress-bar{
height:6px;
background:var(--bg-secondary);
border-radius:3px;
overflow:hidden;
}
.progress-fill{
height:100%;
border-radius:3px;
transition:width 0.5s ease;
position:relative;
}
.progress-fill::after{
content:'';
position:absolute;
top:0;left:0;right:0;bottom:0;
background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent);
}
.status-dot{
width:8px;
height:8px;
border-radius:50%;
background:var(--accent-green);
animation:pulse 2s ease-in-out infinite;
box-shadow:0 0 8px var(--accent-green);
}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.9)}}
(api-category){display:flex;flex-direction:column;gap:0.5rem}
(api-category) summary{
display:flex;
align-items:center;
gap:0.5rem;
padding:0.5rem 0;
cursor:pointer;
font-weight:600;
color:var(--text-primary);
list-style:none;
}
(api-category) summary::before{
content:'▶';
font-size:0.625rem;
transition:transform 0.2s;
color:var(--text-muted);
}
(api-category)[open] summary::before{transform:rotate(90deg)}
(api-category) ul{
padding-left:1rem;
padding-right:1rem;
padding-top:0.5rem;
display:flex;
flex-direction:column;
gap:0.25rem;
}
(api-category) a{
display:flex;
align-items:center;
gap:0.5rem;
padding:0.375rem 0.625rem;
color:var(--text-secondary);
font-size:0.8125rem;
font-family:'JetBrains Mono',monospace;
border-radius:0.375rem;
transition:all 0.2s;
text-decoration:none;
}
(api-category) a:hover{
background:var(--bg-hover);
color:var(--accent-cyan);
}
code{
font-family:'JetBrains Mono',monospace;
background:var(--bg-secondary);
color:var(--accent-cyan);
padding:0.125rem 0.375rem;
border-radius:0.25rem;
font-size:0.8125rem;
}
@media (prefers-reduced-motion:reduce){.status-dot{animation:none}}
</style>
</head>
