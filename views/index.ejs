--color-neutral:#1c212b;
--color-neutral-content:#c7cdda;
--color-info:#5fb6ff;
--color-info-content:#03101c;
--color-success:#2ee6b8;
--color-success-content:#04140f;
--color-warning:#f5b942;
--color-warning-content:#1a1102;
--color-error:#ff6b6e;
--color-error-content:#1a0506;
--radius-box:1rem;
--radius-field:0.6rem;
--radius-selector:1rem;
--border:1px;
--depth:0;
--noise:0;
color-scheme:dark;
}
[data-theme="cyberapi-light"]{
--color-base-100:#f5f6f8;
--color-base-200:#eceff3;
--color-base-300:#e2e6ed;
--color-base-content:#10141c;
--color-primary:#0fb892;
--color-primary-content:#ffffff;
--color-secondary:#6a57e0;
--color-secondary-content:#ffffff;
--color-accent:#2c8fe0;
--color-accent-content:#ffffff;
--color-neutral:#1c212b;
--color-neutral-content:#f5f6f8;
--color-info:#2c8fe0;
--color-info-content:#ffffff;
--color-success:#0fb892;
--color-success-content:#ffffff;
--color-warning:#c98a12;
--color-warning-content:#1a1102;
--color-error:#e0454b;
--color-error-content:#ffffff;
--radius-box:1rem;
--radius-field:0.6rem;
--radius-selector:1rem;
--border:1px;
--depth:0;
--noise:0;
color-scheme:light;
}
body{font-family:'Inter',system-ui,sans-serif;letter-spacing:-0.01em}
.brand-mark{font-family:'Space Grotesk',sans-serif;letter-spacing:0.02em}
.font-display{font-family:'Space Grotesk',sans-serif}
.font-mono{font-family:'JetBrains Mono',monospace}
.status-pill{display:inline-flex;align-items:center;gap:.4rem;font-family:'JetBrains Mono',monospace;font-size:.7rem;letter-spacing:.06em;color:var(--color-primary);padding:.35rem .7rem;border:1px solid color-mix(in oklab, var(--color-primary) 35%, transparent);border-radius:999px;background:color-mix(in oklab, var(--color-primary) 8%, transparent)}
.status-dot{width:.4rem;height:.4rem;border-radius:999px;background:var(--color-primary);animation:pulseDot 2s ease-in-out infinite}
@keyframes pulseDot{0%,100%{opacity:1}50%{opacity:.4}}
.stat-card{position:relative;overflow:hidden;border:1px solid var(--color-base-300)}
.stat-card::before,.stat-card::after{content:"";position:absolute;width:14px;height:14px;border-color:color-mix(in oklab, var(--color-primary) 55%, transparent);opacity:.6;pointer-events:none}
.stat-card::before{top:10px;right:10px;border-top:1.5px solid;border-right:1.5px solid}
.stat-card::after{bottom:10px;left:10px;border-bottom:1.5px solid;border-left:1.5px solid}
.stat-eyebrow{font-family:'JetBrains Mono',monospace;font-size:.7rem;letter-spacing:.12em;opacity:.55}
.stat-value{font-family:'JetBrains Mono',monospace;font-weight:600;letter-spacing:-0.02em}
.perf-label{font-size:.85rem;opacity:.75}
.perf-value{font-family:'JetBrains Mono',monospace;font-weight:600;font-size:.85rem}
.chip-avatar{border-color:var(--color-base-300)}
a:focus-visible,button:focus-visible,.btn:focus-visible{outline:2px solid var(--color-primary);outline-offset:2px}
@media (prefers-reduced-motion: reduce){.status-dot{animation:none}}
</style>
