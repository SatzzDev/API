<style>
[data-theme="cyberapi"]{
--color-base-100:#12161d;
--color-base-200:#0a0d12;
--color-base-300:#1c212b;
--color-base-content:#e8ecf2;
--color-primary:#2ee6b8;
--color-primary-content:#04140f;
--color-secondary:#8c7cf7;
