<script>
const themeToggles=document.querySelectorAll('.theme-controller');
function applyTheme(isLight){
document.documentElement.setAttribute('data-theme',isLight?'cyberapi-light':'cyberapi');
themeToggles.forEach(c=>{c.checked=isLight});
}
themeToggles.forEach(c=>c.addEventListener('change',()=>applyTheme(c.checked)));
</script>
